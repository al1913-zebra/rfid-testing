{
  "title": "config_events",
  "x-stoplight": {
    "id": "puyt4jkcelxao"
  },
  "description": "Enables or disables specific device events. To apply the changes, a device reboot is required.",
  "type": "object",
  "examples": [
    {
      "command": "config_events",
      "requestId": "abc123",
      "eventConfiguration": {
        "terminalConnection": true,
        "firmwareUpdate": true,
        "network": true,
        "heartbeat": true,
        "power": true,
        "battery": true,
        "temperature": true,
        "fileDownload": true,
        "heartbeatConfiguration": {
          "interval": 100,
          "inventoryStatus": true,
          "batteryStatus": true
        }
      }
    },
    {
      "command": "config_events",
      "requestId": "abc123",
      "eventConfiguration": {
        "terminalConnection": true,
        "firmwareUpdate": true,
        "network": true,
        "heartbeat": false,
        "power": true,
        "battery": true,
        "fileDownload": true
      }
    }
  ],
  "properties": {
    "command": {
      "type": "string",
      "example": "config_events",
      "description": "Command issued to configure events & alert threshold values"
    },
    "requestId": {
      "type": "string",
      "example": "abc123",
      "description": "A unique identifier for the request, allowing tracking and debugging of the operation."
    },
    "eventConfiguration": {
      "$ref": "../../refrence/payload/cfgEventPayload.yaml"
    }
  },
  "required": [
    "command",
    "requestId"
  ]
}