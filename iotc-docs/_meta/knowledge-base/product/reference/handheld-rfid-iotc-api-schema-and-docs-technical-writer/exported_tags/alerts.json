                              "type": "object",
                              "description": "Information regarding file download events, such as source, destination, and status.",
                              "properties": {
                                "fileType": {
                                  "type": "string",
                                  "enum": [
                                    "FILE_TYPE_FW",
                                    "FILE_TYPE_CERT"
