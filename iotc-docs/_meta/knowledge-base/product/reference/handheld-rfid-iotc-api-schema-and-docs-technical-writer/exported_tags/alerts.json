    "/alerts": {
      "post": {
        "tags": [
          "Alerts"
        ],
        "summary": "Alerts",
        "description": "The alerts event provides detailed, structured alert information from the device for operational monitoring and troubleshooting.\n\nThis event includes:\n- Alert type, state, and priority classification\n- A structured alertDetails payload with domain-specific fields\n- Alert identifiers covering battery, power, firmware, and network conditions\n\nUse this event to:\n- Monitor important status transitions and critical conditions\n- Track device health and infrastructure-related changes\n- Feed alert pipelines that require structured alert context\n\n### Event Details\n\n| Property | Value |\n|---|---|\n| Event Type | Alert |\n| Communication Type | Device to Cloud |\n| Applies To | RFD40 Series, RFD90 Series |\n| Trigger Condition | Generated when a device condition transitions state or crosses a monitored threshold |\n| Related Events | [alert_short](#op-alert-short), [heartBeatEVT](#op-heartbeat-evt), [exceptionEVT](#op-exception-evt) |\n| Supported API Versions | V1.0, V1.1 |",
        "responses": {
          "default": {
            "description": "alerts event payload",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "enum": [
                        "EVENT",
                        "NOTIFICATION",
                        "EXCEPTION",
                        "ALERT"
                      ],
                      "description": "Specifies the type of alert or message being generated, such as an event, notification, exception, or alert."
                    },
                    "timestamp": {
                      "type": "string",
                      "format": "time",
                      "example": "22:54:25",
                      "description": "Indicates the time at which the alert was generated, formatted as a time string."
                    },
                    "state": {
                      "type": "string",
                      "enum": [
                        "SET",
                        "CLEAR",
                        "ONESHOT"
                      ],
                      "description": "Represents the state of the alert. 'SET' indicates an active alert, 'CLEAR' indicates the alert has been resolved, and 'ONESHOT' is a one-time alert."
                    },
                    "id": {
                      "type": "string",
                      "enum": [
                        "BATTERY",
                        "FIRMWARE_UPDATE",
                        "GPI_EVENT",
                        "NETWORK_EVENT",
                        "ANTENNA_EVENT",
                        "TEMPERATURE",
                        "POWER"
                      ],
                      "example": "BATTERY",
                      "description": "A unique identifier for the alert type, such as a low battery warning or a temperature event."
                    },
                    "priority": {
                      "type": "string",
                      "example": "CRITICAL",
                      "enum": [
                        "CRITICAL",
                        "HIGH",
                        "MEDIUM",
                        "LOW"
                      ],
                      "description": "Defines the priority level of the alert, ranging from critical to low."
                    },
                    "alertDetails": {
                      "anyOf": [
                        {
                          "type": "object",
                          "description": "Object schema for alertDetails.",
                          "x-stoplight": {
                            "id": "a15e9b2d754c2"
                          },
                          "title": "alertDetails",
                          "properties": {
